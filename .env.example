# =============================================================================
# .env.example — Agentic AI-Powered Incident Resolution System — Pellera Hackathon 2026
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it contains API keys.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your real values
#   python agent2_analyst.py --inference-route orchestrate
# =============================================================================


# ── Watson Orchestrate ────────────────────────────────────────────────────────

# Your IBM Cloud API key — used to obtain MCSP tokens
# Found at: cloud.ibm.com → Manage → Access → API keys
ORCHESTRATE_API_KEY=your_ibm_cloud_api_key_here

# Watson Orchestrate instance URL
# Found at: Watson Orchestrate UI → Settings → API details
ORCHESTRATE_INSTANCE_URL=https://api.dl.watson-orchestrate.ibm.com/instances/your_instance_id

# AIOps_RCA_Agent agent ID — used by Agent 2 for LLM inference
# Found at: Watson Orchestrate → Manage agents → AIOps_RCA_Agent → URL
ORCHESTRATE_RCA_AGENT_ID=your_rca_agent_uuid_here

# AIOps_Incident_Resolution_Manager agent ID — used by Agent 3 to create SNOW tickets
# Found at: Watson Orchestrate → Manage agents → AIOps_Incident_Resolution_Manager → URL
ORCHESTRATE_AGENT_ID=your_incident_manager_agent_uuid_here

# Watson Orchestrate Knowledge Base name — must match KB created in WO UI
# Default: aiops-incident-patterns-kb
ORCHESTRATE_KB_NAME=aiops-incident-patterns-kb

# Watson Orchestrate UI URL — used in Teams adaptive card buttons
# Do not include trailing slash
WO_UI_URL=https://dl.watson-orchestrate.ibm.com


# ── IBM watsonx.ai (optional — only needed for --inference-route watsonx) ────

# IBM Cloud API key for watsonx.ai (can be same as ORCHESTRATE_API_KEY)
WATSONX_API_KEY=your_ibm_cloud_api_key_here

# watsonx.ai project ID
# Found at: dataplatform.cloud.ibm.com → Projects → your project → Manage → General
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# watsonx.ai endpoint URL (region-specific)
WATSONX_URL=https://us-south.ml.cloud.ibm.com


# ── ServiceNow ────────────────────────────────────────────────────────────────

# Your ServiceNow developer instance URL (include https://)
SNOW_INSTANCE_URL=https://dev123456.service-now.com


# ── Email (SMTP) ──────────────────────────────────────────────────────────────

# SMTP server — Gmail shown as default
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your sender email address
SMTP_USER=your_email@gmail.com

# Gmail: use a 16-character App Password (not your account password)
# Create at: myaccount.google.com → Security → App passwords
SMTP_PASS=your_16_char_app_password

# Recipient email address for SRE notifications
EMAIL_TO=sre_oncall@yourcompany.com


# ── Microsoft Teams ───────────────────────────────────────────────────────────

# Incoming Webhook URL for your Teams channel
# Created at: Teams channel → Connectors → Incoming Webhook
TEAMS_WEBHOOK_URL=https://yourorg.webhook.office.com/webhookb2/your_webhook_path


# ── Model display ─────────────────────────────────────────────────────────────

# Display name for the LLM model (shown in logs and reports)
# Does not affect which model is called — that is set in Watson Orchestrate
#MODEL_ID=ibm/granite-4-h-small
MODEL_ID=GPT OSS 120B
MODEL_DISPLAY_NAME=GPT OSS 120B


# ── Organisation ─────────────────────────────────────────────────────────────

# Your organisation name — appears in email subjects, Teams cards, log banners
ORGANIZATION_NAME=YourCompany

# Project name — appears in agent startup banners and documentation strings
PROJECT_NAME=Agentic AI-Powered Incident Resolution System


# ── Runtime ──────────────────────────────────────────────────────────────────

# Local HTTP server port for RCA report cards (Teams "View RCA Report" button)
# Must be free on your machine when Agent 3 runs
RCA_SERVER_PORT=8099
