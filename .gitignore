# =============================================================================
# .gitignore — Agentic AI-Powered Incident Resolution System — Pellera Hackathon 2026
# =============================================================================

# ── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
*.key
*.pem
*.p12

# ── Runtime outputs — generated fresh every run ───────────────────────────────
rca_output.json
snow_ready.json
ticket_log.json

# ── Agent 3 generates this before importing to Orchestrate ────────────────────
kb_config.yaml

# ── KB documents — auto-generated by Agent 2, auto-uploaded by Agent 3 ───────
# These change every run and contain real incident data.
# Judges can regenerate them by running the full pipeline.
kb_documents/

# ── HTML report cards — generated by Agent 2 for each incident ───────────────
rca_reports/

# ── Per-run ServiceNow ticket copies ─────────────────────────────────────────
snow_tickets/

# ── Python bytecode ───────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── IDE and OS files ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Test artefacts ────────────────────────────────────────────────────────────
.pytest_cache/
*.coverage
htmlcov/

# =============================================================================
# What IS committed (for reference):
#   agent1_correlator.py      — source code
#   agent2_analyst.py         — source code
#   agent3_notify.py          — source code
#   kb_utils.py               — source code
#   runbook_tool.py           — Watson Orchestrate ADK tool
#   mark_resolved_tool.py     — Watson Orchestrate ADK tool
#   config/*.yaml             — configuration (no secrets)
#   Hackathon.txt             — demo input data for Agent 1
#   .env.example              — template with placeholder values only
#   requirements.txt          — Python dependencies
#   README.md                 — quick start guide
#   docs/                     — architecture and roadmap docs
# =============================================================================
